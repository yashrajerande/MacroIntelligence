{
  "type": "object",
  "required": ["generated_at", "run_date", "indicators"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "run_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "indicators": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/indicator" },
      "propertyNames": {
        "enum": [
          "india_gdp_yoy", "india_gdp_fy_estimate", "rbi_gdp_forecast",
          "pmi_mfg", "pmi_services", "pmi_composite",
          "iip_yoy", "iip_capgoods", "capacity_utilisation", "core_sector_yoy",
          "cpi_headline", "cpi_core", "cfpi_food", "wpi", "fuel_inflation",
          "rbi_repo_rate", "rbi_inflation_forecast",
          "gst_month", "gst_ytd", "pv_sales", "2w_sales", "cv_sales",
          "airline_pax", "ecom_gmv_growth",
          "bank_credit_growth", "deposit_growth", "cd_ratio",
          "nbfc_credit_growth", "corp_bond_issuance",
          "fii_equity_net", "dii_equity_net", "sip_inflows", "sip_yoy_growth",
          "mf_aum", "mf_avg_aum", "equity_mf_net", "nfo_collections",
          "sip_accounts", "sip_aum",
          "rbi_fx_reserves",
          "us_gdp_saar", "china_gdp", "ez_gdp",
          "global_pmi_composite", "us_pmi_composite", "china_pmi_composite",
          "us_cpi", "us_core_cpi", "us_core_pce", "ez_cpi", "china_cpi",
          "fao_food_index",
          "fed_funds_rate", "fed_balance_sheet", "ecb_deposit_rate",
          "boj_rate", "us_10y_treasury", "dxy"
        ]
      }
    }
  },
  "$defs": {
    "indicator": {
      "type": "object",
      "required": ["value", "direction", "source", "vintage", "confidence"],
      "properties": {
        "value":           { "type": ["number", "null"] },
        "value_str":       { "type": "string" },
        "previous":        { "type": ["number", "null"] },
        "change_pct":      { "type": ["number", "null"] },
        "direction":       { "type": "string", "enum": ["up", "down", "flat"] },
        "source":          { "type": "string" },
        "vintage":         { "type": "string" },
        "is_estimated":    { "type": "boolean", "default": false },
        "pct_10y":         { "type": "integer", "minimum": 0, "maximum": 100 },
        "pct_10y_tier":    { "type": "string", "enum": ["hi", "mid", "lo"] },
        "momentum_label":  { "type": "string" },
        "confidence":      { "type": "string", "enum": ["high", "medium", "low"] }
      }
    }
  }
}
