    "scenarios": "node agents/Analysis/ScenarioPlanner/plan.js",
    "summary": "node agents/Editorial/ExecutiveSummaryWriter/write.js",
    "news": "node agents/Editorial/NewsCurator/curate.js",
    "render": "node agents/Production/DashboardRenderer/render.js",
